{
  "app": {
    "name": "oTools",
    "version": "1.0.0",
    "description": "A feature-rich desktop application management center"
  },
  "window": {
    "width": 480,
    "height": 420,
    "alwaysOnTop": true,
    "skipTaskbar": true
  },
  "plugins": {
    "autoLoad": true,
    "maxProcesses": 10
  },
  "logging": {
    "level": "info",
    "enableFile": true,
    "logFile": "logs/otools.log",
    "enableConsole": true,
    "maxFileSize": "10MB",
    "maxFiles": 5,
    "format": "json"
  },
  "shortcuts": {
    "toggle": "Alt+Space",
    "screenshot": "CommandOrControl"
  },
  "security": {
    "enableSandbox": true,
    "allowedAPIs": [
      "captureScreenRegion",
      "performOCR",
      "captureAndOCR",
      "cleanup"
    ]
  }
}
{
  "app": {
    "name": "oTools",
    "version": "1.0.0",
    "debug": false,
    "description": "A feature-rich desktop application management center"
  },
  "window": {
    "width": 480,
    "height": 420,
    "alwaysOnTop": true,
    "skipTaskbar": true
  },
  "plugins": {
    "autoLoad": true,
    "maxProcesses": 10,
    "timeout": 30000,
    "retryAttempts": 2,
    "retryDelay": 1000,
    "enableAutoStart": true
  },
  "logging": {
    "level": "info",
    "enableFile": true,
    "logFile": "logs/otools.log",
    "enableConsole": true,
    "maxFileSize": "10MB",
    "maxFiles": 5,
    "format": "json"
  },
  "shortcuts": {
    "toggle": "Alt+K",
    "screenshot": "CommandOrControl"
  },
  "performance": {
    "enableMonitoring": true,
    "thresholds": {
      "pluginExecution": 5000,
      "apiCall": 1000,
      "fileOperation": 2000
    },
    "enableAlerts": true,
    "alertThreshold": 10000
  },
  "errorHandling": {
    "maxErrors": 100,
    "retryAttempts": 3,
    "retryDelay": 1000,
    "enableNotifications": true,
    "logErrors": true
  },
  "ui": {
    "theme": "default",
    "language": "en-US",
    "window": {
      "width": 480,
      "height": 420,
      "minWidth": 400,
      "minHeight": 300
    }
  },
  "security": {
    "enableSandbox": true,
    "allowedAPIs": [
      "captureScreenRegion",
      "performOCR",
      "captureAndOCR",
      "cleanup"
    ]
  }
}